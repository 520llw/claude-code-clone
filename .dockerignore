# =============================================================================
# Docker Ignore File
# =============================================================================
# Files and directories to exclude from Docker build context
# =============================================================================

# Git
.git
.gitignore
.gitattributes
.gitmodules

# Node.js
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm
.yarn
.pnp.*

# Build outputs
build
dist
coverage
.nyc_output
*.tsbuildinfo

# Logs
logs
*.log

# Environment files
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production

# IDE and editors
.idea
.vscode
*.swp
*.swo
*~
.DS_Store
*.sublime-project
*.sublime-workspace
.project
.classpath
.settings

# Testing
test
tests
__tests__
*.test.ts
*.test.js
*.spec.ts
*.spec.js
jest.config.js
coverage/
.nyc_output/

# Documentation (except what's needed)
docs/*.md
*.md
!README.md
!CHANGELOG.md
!LICENSE

# CI/CD
.github
.gitlab-ci.yml
.travis.yml
.azure-pipelines.yml

# Package manager files
package-lock.json
yarn.lock
pnpm-lock.yaml

# Temporary files
tmp
temp
*.tmp
*.temp
.cache

# OS files
Thumbs.db
.DS_Store
*.lnk

# Binary files
*.exe
*.dll
*.so
*.dylib
*.bin

# Archives
*.zip
*.tar.gz
*.tar
*.rar
*.7z

# Docker files (avoid recursion)
Dockerfile*
docker-compose*.yml
.dockerignore

# Misc
.eslintrc*
.prettierrc*
.editorconfig
.husky
.lintstagedrc*
.commitlintrc*

# Large files
*.mp4
*.mov
*.avi
*.pdf
