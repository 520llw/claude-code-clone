{
  "name": "claude-code-clone",
  "version": "1.0.0",
  "description": "A full-featured Claude Code clone - AI-powered terminal coding assistant",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "claude-code": "dist/cli.js",
    "ccode": "dist/cli.js"
  },
  "scripts": {
    "build": "node scripts/build.js",
    "build:prod": "NODE_ENV=production node scripts/build.js",
    "pack": "node scripts/pack.js",
    "pack:all": "node scripts/pack.js --all",
    "test": "jest --coverage",
    "test:ci": "jest --coverage --ci --reporters=default --reporters=jest-junit",
    "test:e2e": "jest --config=jest.e2e.config.js --testPathPattern=tests/e2e",
    "test:integration": "jest --config=jest.integration.config.js --testPathPattern=tests/integration",
    "test:perf": "jest --config=jest.perf.config.js --testPathPattern=tests/performance",
    "lint": "eslint src/ --ext .ts,.tsx",
    "lint:fix": "eslint src/ --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist/ build/ *.tgz",
    "prepublishOnly": "npm run clean && npm run build:prod && npm run test",
    "postinstall": "node scripts/postinstall.js",
    "version": "node scripts/version.js",
    "release": "node scripts/release.js",
    "docker:build": "docker build -t claude-code-clone:latest .",
    "docker:run": "docker run -it --rm claude-code-clone:latest"
  },
  "keywords": [
    "claude",
    "ai",
    "assistant",
    "code",
    "terminal",
    "cli",
    "coding",
    "llm",
    "anthropic"
  ],
  "author": "Claude Code Clone Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourorg/claude-code-clone.git"
  },
  "bugs": {
    "url": "https://github.com/yourorg/claude-code-clone/issues"
  },
  "homepage": "https://github.com/yourorg/claude-code-clone#readme",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "conf": "^12.0.0",
    "diff": "^5.1.0",
    "execa": "^8.0.1",
    "globby": "^14.0.0",
    "ink": "^4.4.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^5.0.1",
    "inquirer": "^9.2.12",
    "node-fetch": "^3.3.2",
    "ora": "^8.0.1",
    "react": "^18.2.0",
    "semver": "^7.5.4",
    "simple-git": "^3.20.0",
    "tar": "^6.2.0",
    "tmp": "^0.2.1",
    "update-notifier": "^7.0.0",
    "which": "^4.0.0",
    "winston": "^3.11.0",
    "yauzl": "^2.10.0",
    "yazl": "^2.5.1"
  },
  "devDependencies": {
    "@types/diff": "^5.0.8",
    "@types/inquirer": "^9.0.7",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.9.0",
    "@types/react": "^18.2.37",
    "@types/semver": "^7.5.5",
    "@types/tar": "^6.1.10",
    "@types/tmp": "^0.2.6",
    "@types/update-notifier": "^6.0.8",
    "@types/which": "^3.0.3",
    "@types/yauzl": "^2.10.3",
    "@typescript-eslint/eslint-plugin": "^6.12.0",
    "@typescript-eslint/parser": "^6.12.0",
    "esbuild": "^0.19.6",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.29.0",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "prettier": "^3.1.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.2",
    "pkg": "^5.8.1"
  },
  "files": [
    "dist/",
    "scripts/postinstall.js",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "pkg": {
    "scripts": [
      "dist/**/*.js"
    ],
    "assets": [
      "dist/**/*",
      "node_modules/**/*"
    ],
    "targets": [
      "node18-macos-x64",
      "node18-macos-arm64",
      "node18-linux-x64",
      "node18-linux-arm64",
      "node18-win-x64"
    ],
    "outputPath": "build/binaries"
  }
}
